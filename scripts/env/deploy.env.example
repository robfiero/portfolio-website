# AWS S3 and CloudFront deployment configuration
# Copy this file to scripts/env/deploy.env and update with your actual values

# S3 bucket name for deployment
BUCKET=robfiero.net

# CloudFront distribution ID for cache invalidation
DISTRIBUTION_ID=E2RFWU7V0VNNEO

# AWS region
AWS_REGION=us-east-1

# AWS profile (optional; leave empty to use default credentials)
AWS_PROFILE=

# Local build directory
DIST_DIR=dist

# CloudFront paths to invalidate
PATHS=/*